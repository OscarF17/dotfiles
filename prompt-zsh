# Enable native Zsh color support
autoload -Uz colors && colors

# Define your prompt colors using Zsh native syntax
BLACK="%F{0}"
RED="%F{1}"
GREEN="%F{2}"
YELLOW="%F{3}"
BLUE="%F{4}"
PURPLE="%F{5}"
CYAN="%F{6}"
WHITE="%F{7}"
GRAY="%F{8}"
BRIGHT_RED="%F{9}"
BRIGHT_GREEN="%F{10}"
BRIGHT_YELLOW="%F{11}"
BRIGHT_BLUE="%F{12}"
BRIGHT_PURPLE="%F{13}"
BRIGHT_CYAN="%F{14}"
RESET="%f"

# Set the prompt (Zsh uses PROMPT or PS1 interchangeably)
PROMPT="
${RED}%n${RESET}@%~
$> "
